<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Neelgiri Chemicals — Paint Industry Leader</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════════
   ROOT & RESET
══════════════════════════════════════════ */
:root {
  --blue: #0078BF;
  --blue2: #0065a8;
  --blue3: #004e80;
  --dark: #f4f7fb;
  --dark2: #e8eef6;
  --white: #1a2535;
  --gray: rgba(26,37,53,0.6);
  --gray2: rgba(26,37,53,0.2);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;overflow-x:hidden}
body{
  font-family:'Outfit',sans-serif;
  background:#f4f7fb;color:#1a2535;
  overflow-x:hidden;cursor:none;
}

/* ── custom cursor ── */
#cursor{
  position:fixed;top:0;left:0;z-index:9999;pointer-events:none;
  width:14px;height:14px;border-radius:50%;
  background:var(--blue);mix-blend-mode:multiply;
  transition:transform .12s ease;
  transform:translate(-50%,-50%);
}
#cursor-ring{
  position:fixed;top:0;left:0;z-index:9998;pointer-events:none;
  width:44px;height:44px;border-radius:50%;
  border:1.5px solid rgba(0,120,191,0.5);
  transform:translate(-50%,-50%);
  transition:all .28s ease;
}

/* ── noise overlay ── */
body::before{
  content:'';position:fixed;inset:0;z-index:9990;pointer-events:none;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity:.025;
}

/* ── scrollbar ── */
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:#e8eef6}
::-webkit-scrollbar-thumb{background:var(--blue);border-radius:2px}

/* ══════════════════════════════════════════
   NAV
══════════════════════════════════════════ */
#nav{
  position:fixed;inset:0 0 auto 0;z-index:1000;
  height:62px;display:flex;align-items:center;
  justify-content:space-between;padding:0 5%;
  transition:background .4s,backdrop-filter .4s;
}
#nav.scrolled{
  background:rgba(255,255,255,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(0,120,191,0.15);
  box-shadow:0 2px 20px rgba(0,80,160,0.08);
}
.nav-logo{
  display:flex;align-items:center;gap:10px;
  text-decoration:none;
}
.nav-logo svg{flex-shrink:0}
.nav-links{display:flex;gap:30px;list-style:none}
.nav-links a{
  font-size:12px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(26,37,53,0.55);text-decoration:none;transition:color .2s;
}
.nav-links a:hover{color:#0078BF}
.nav-buy{
  background:var(--blue);color:white;
  font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  padding:9px 22px;border-radius:30px;text-decoration:none;
  box-shadow:0 0 20px rgba(0,120,191,0.4);
  transition:all .25s;
}
.nav-buy:hover{background:var(--blue2);transform:translateY(-2px);box-shadow:0 0 35px rgba(0,168,255,0.5)}

/* ══════════════════════════════════════════
   SECTION 1 — CINEMATIC HERO
══════════════════════════════════════════ */
#s1{
  height:100vh;position:relative;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
}
.s1-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 110%, rgba(0,120,191,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 60% 80% at 80% 20%, rgba(0,100,200,0.1) 0%, transparent 60%),
    linear-gradient(180deg,#ddeaf8 0%,#e8f2fd 50%,#f0f6ff 100%);
}
/* Animated scan line */
.s1-scan{
  position:absolute;inset:0;
  background:repeating-linear-gradient(
    0deg,transparent,transparent 2px,
    rgba(0,100,180,0.04) 2px,rgba(0,100,180,0.04) 4px
  );pointer-events:none;
}
/* The giant glowing orb */
.s1-orb{
  position:absolute;bottom:-30%;left:50%;transform:translateX(-50%);
  width:700px;height:700px;border-radius:50%;
  background:radial-gradient(circle at 40% 35%,
    rgba(255,255,255,0.9) 0%,
    rgba(180,220,255,0.7) 20%,
    rgba(0,120,191,0.25) 45%,
    rgba(0,80,160,0.12) 70%,
    transparent 100%);
  box-shadow:0 0 120px rgba(0,120,191,0.15),0 0 300px rgba(0,80,160,0.08);
  animation:orbBreath 8s ease-in-out infinite;
}
@keyframes orbBreath{
  0%,100%{box-shadow:0 0 120px rgba(0,120,191,0.15),0 0 300px rgba(0,80,160,0.08)}
  50%{box-shadow:0 0 180px rgba(0,120,191,0.22),0 0 400px rgba(0,80,160,0.12)}
}
/* Chemical molecule float */
.mol{
  position:absolute;border-radius:50%;
  animation:molFloat ease-in-out infinite;
}
@keyframes molFloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-30px) rotate(10deg)}}

.s1-content{
  position:relative;z-index:10;text-align:center;
  padding:0 20px;
}
.s1-label{
  font-size:11px;font-weight:600;letter-spacing:0.25em;text-transform:uppercase;
  color:var(--blue);margin-bottom:20px;
  display:inline-flex;align-items:center;gap:10px;
  animation:fadeUp .8s ease both;
}
.s1-label::before,.s1-label::after{content:'';width:30px;height:1px;background:var(--blue)}
.s1-h1{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(64px,10vw,140px);
  line-height:0.92;letter-spacing:0.01em;
  background:linear-gradient(180deg,#0a1e35 0%,#1a4a80 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:fadeUp .8s .15s ease both;
}
.s1-h1 .glow-word{
  background:linear-gradient(135deg,#0078BF,#0065a8,#004e80);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  text-shadow:none;filter:drop-shadow(0 0 40px rgba(0,168,255,0.5));
}
.s1-sub{
  font-size:clamp(13px,1.8vw,18px);font-weight:300;
  color:rgba(26,37,53,0.55);margin-top:20px;
  letter-spacing:0.04em;max-width:600px;margin-left:auto;margin-right:auto;
  animation:fadeUp .8s .3s ease both;
}
.s1-actions{
  display:flex;gap:16px;justify-content:center;margin-top:40px;flex-wrap:wrap;
  animation:fadeUp .8s .45s ease both;
}
.btn-primary-glow{
  background:linear-gradient(135deg,var(--blue),var(--blue2));
  color:white;font-size:13px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;
  padding:14px 36px;border-radius:40px;text-decoration:none;
  box-shadow:0 0 30px rgba(0,120,191,0.5),0 0 0 1px rgba(0,168,255,0.2);
  transition:all .3s;
}
.btn-primary-glow:hover{transform:translateY(-3px);box-shadow:0 0 60px rgba(0,120,191,0.7),0 0 0 1px rgba(0,168,255,0.4)}
.btn-ghost-light{
  border:1px solid rgba(0,120,191,0.35);
  color:rgba(0,80,160,0.85);font-size:13px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  padding:14px 36px;border-radius:40px;text-decoration:none;
  transition:all .3s;
}
.btn-ghost-light:hover{border-color:#0078BF;color:#0078BF}

/* scroll indicator */
.s1-scroll{
  position:absolute;bottom:32px;left:50%;transform:translateX(-50%);
  display:flex;flex-direction:column;align-items:center;gap:8px;
  animation:fadeUp .8s .7s ease both;
}
.s1-scroll-text{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:rgba(26,37,53,0.35)}
.s1-scroll-line{width:1px;height:40px;background:linear-gradient(180deg,rgba(0,168,255,0.6),transparent);animation:scrollDrop 2s ease-in-out infinite}
@keyframes scrollDrop{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}

@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

/* ══════════════════════════════════════════
   SPECS TICKER
══════════════════════════════════════════ */
#ticker{
  background:rgba(0,120,191,0.07);
  border-top:1px solid rgba(0,120,191,0.15);
  border-bottom:1px solid rgba(0,120,191,0.15);
  padding:14px 0;overflow:hidden;
}
.ticker-inner{
  display:flex;gap:0;
  animation:tickerScroll 25s linear infinite;
  width:max-content;
}
.ticker-item{
  display:flex;align-items:center;gap:8px;
  padding:0 40px;
  font-size:12px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;
  color:rgba(26,37,53,0.5);white-space:nowrap;
  border-right:1px solid rgba(0,80,160,0.1);
}
.ticker-item .dot{width:5px;height:5px;border-radius:50%;background:var(--blue2);flex-shrink:0}
@keyframes tickerScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ══════════════════════════════════════════
   SCROLL SECTIONS (Realme-style)
   Each section: full-height, sticky visual + text reveal
══════════════════════════════════════════ */
.scroll-chapter{
  position:relative;
}

/* ──────────────────────────────────────────
   CHAPTER A — About | sticky split
────────────────────────────────────────── */
#chA{
  min-height:200vh;
  background:linear-gradient(180deg,#f4f7fb 0%,#eaf2fd 40%,#f4f7fb 100%);
}
#chA .sticky-panel{
  position:sticky;top:0;height:100vh;
  display:grid;grid-template-columns:1fr 1fr;
  overflow:hidden;
}
#chA .panel-left{
  display:flex;flex-direction:column;justify-content:center;
  padding:80px 6% 80px 8%;
}
#chA .panel-right{
  position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;
}

/* Giant text behind visual */
.bg-text{
  position:absolute;
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(120px,16vw,220px);
  color:rgba(0,120,191,0.07);
  letter-spacing:-0.02em;line-height:1;
  user-select:none;pointer-events:none;
  white-space:nowrap;
}

/* Chapter label */
.chap-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:11px;letter-spacing:0.25em;text-transform:uppercase;
  color:var(--blue2);margin-bottom:16px;
  display:flex;align-items:center;gap:12px;
}
.chap-num::before{content:'';width:24px;height:1px;background:var(--blue2)}

.chap-h2{
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(44px,6vw,84px);
  line-height:0.95;letter-spacing:0.01em;color:#0a1e35;margin-bottom:20px;
}
.chap-h2 em{color:var(--blue2);font-style:normal}
.chap-body{
  font-size:15px;font-weight:300;line-height:1.85;
  color:rgba(26,37,53,0.55);max-width:460px;margin-bottom:32px;
}

/* Animated stat pills */
.stat-row{
  display:flex;gap:14px;flex-wrap:wrap;margin-top:28px;
}
.stat-pill{
  background:rgba(0,120,191,0.07);
  border:1px solid rgba(0,120,191,0.2);
  border-radius:12px;padding:16px 22px;
  transition:all .3s;cursor:default;
}
.stat-pill:hover{background:rgba(0,120,191,0.14);border-color:rgba(0,120,191,0.4);transform:translateY(-4px)}
.stat-pill .num{
  font-family:'Bebas Neue',sans-serif;
  font-size:36px;line-height:1;color:#0a1e35;letter-spacing:0.02em;
}
.stat-pill .num span{font-size:18px;color:var(--blue2)}
.stat-pill .lbl{font-size:11px;font-weight:500;color:rgba(26,37,53,0.45);letter-spacing:0.08em;margin-top:3px}

/* ──────────────────────────────────────────
   BIG VISUAL / 3D MOLECULE CANVAS
────────────────────────────────────────── */
.mol-canvas{
  position:relative;width:420px;height:420px;
}
.mol-core{
  position:absolute;inset:0;border-radius:50%;
  background:radial-gradient(ellipse at 38% 30%,
    rgba(255,255,255,0.95) 0%,
    rgba(180,220,255,0.7) 25%,
    rgba(0,120,191,0.45) 55%,
    rgba(0,60,140,0.65) 100%);
  box-shadow:
    inset -18px -18px 40px rgba(0,20,60,0.5),
    inset 14px 14px 30px rgba(255,255,255,0.07),
    0 0 80px rgba(0,120,191,0.35),
    0 0 200px rgba(0,80,160,0.15);
  animation:molCorePulse 5s ease-in-out infinite;
}
@keyframes molCorePulse{
  0%,100%{box-shadow:inset -18px -18px 40px rgba(0,20,60,0.5),inset 14px 14px 30px rgba(255,255,255,0.07),0 0 80px rgba(0,120,191,0.35),0 0 200px rgba(0,80,160,0.15)}
  50%{box-shadow:inset -18px -18px 40px rgba(0,20,60,0.5),inset 14px 14px 30px rgba(255,255,255,0.09),0 0 120px rgba(0,120,191,0.5),0 0 280px rgba(0,80,160,0.22)}
}
.mol-ring{
  position:absolute;border-radius:50%;border:1.5px solid;
  top:50%;left:50%;transform:translate(-50%,-50%);
}
.mr1{width:480px;height:480px;border-color:rgba(0,120,191,0.25);animation:ringR 20s linear infinite}
.mr2{width:540px;height:540px;border-color:rgba(0,120,191,0.12);border-style:dashed;animation:ringR 35s linear infinite reverse}
.mr3{width:590px;height:590px;border-color:rgba(0,168,255,0.08);animation:ringR 50s linear infinite}
@keyframes ringR{from{transform:translate(-50%,-50%) rotate(0)}to{transform:translate(-50%,-50%) rotate(360deg)}}
.mr1-dot{
  position:absolute;width:10px;height:10px;border-radius:50%;
  background:var(--blue2);top:-5px;left:50%;transform:translateX(-50%);
  box-shadow:0 0 14px var(--blue2);
}
.mol-node-sm{
  position:absolute;border-radius:50%;
  background:radial-gradient(ellipse at 35% 30%,rgba(255,255,255,0.85),rgba(0,140,220,0.5),rgba(0,40,120,0.8));
  box-shadow:inset -3px -3px 6px rgba(0,20,60,0.4),inset 2px 2px 5px rgba(255,255,255,0.5),0 4px 14px rgba(0,100,200,0.3);
  animation:nodeSmFloat ease-in-out infinite;
}
@keyframes nodeSmFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

/* ══════════════════════════════════════════
   CHAPTER B — Products | dark showcase
══════════════════════════════════════════ */
#chB{
  background:#f0f6ff;
  padding:120px 8%;
}
.chB-header{text-align:center;margin-bottom:80px}
.products-showcase{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:2px;position:relative;
}
.prod-card{
  position:relative;overflow:hidden;
  background:linear-gradient(145deg,#ffffff,#f5f9ff);
  border:1px solid rgba(0,120,191,0.12);
  padding:50px 36px;
  transition:all .5s cubic-bezier(.25,.8,.25,1);
  cursor:default;
}
.prod-card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(0,120,191,0.06),transparent);
  opacity:0;transition:opacity .4s;
}
.prod-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;
  height:2px;
  background:linear-gradient(90deg,transparent,var(--blue),transparent);
  transform:scaleX(0);transition:transform .5s;
}
.prod-card:hover{transform:translateY(-8px);border-color:rgba(0,120,191,0.35);box-shadow:0 24px 60px rgba(0,80,160,0.12),0 0 40px rgba(0,120,191,0.08)}
.prod-card:hover::before{opacity:1}
.prod-card:hover::after{transform:scaleX(1)}
.prod-card:hover .prod-icon{transform:scale(1.1) rotate(-5deg)}

.prod-num{
  font-family:'Bebas Neue',sans-serif;
  font-size:80px;line-height:1;
  color:rgba(0,120,191,0.09);position:absolute;top:10px;right:20px;
}
.prod-icon{
  font-size:44px;margin-bottom:24px;
  display:block;transition:transform .4s;
}
.prod-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:28px;letter-spacing:0.04em;color:#0a1e35;margin-bottom:10px;
}
.prod-desc{
  font-size:13px;font-weight:300;line-height:1.75;
  color:rgba(26,37,53,0.55);
}
.prod-tag{
  display:inline-block;margin-top:18px;
  font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:var(--blue2);padding:5px 12px;
  border:1px solid rgba(0,168,255,0.2);border-radius:20px;
}

/* ══════════════════════════════════════════
   CHAPTER C — Event Sponsorship | cinematic
══════════════════════════════════════════ */
#chC{
  min-height:100vh;position:relative;overflow:hidden;
  display:flex;align-items:center;
  background:linear-gradient(160deg,#e8f2fd 0%,#dceefa 50%,#eaf4ff 100%);
}
.chC-bg{
  position:absolute;inset:0;
  background:
    radial-gradient(ellipse 70% 70% at 70% 50%, rgba(0,100,200,0.1) 0%, transparent 70%),
    radial-gradient(ellipse 50% 80% at 10% 80%, rgba(0,60,140,0.08) 0%, transparent 60%);
}
/* Animated diagonal lines */
.chC-lines{position:absolute;inset:0;overflow:hidden;opacity:.06}
.chC-lines::before,.chC-lines::after{
  content:'';position:absolute;
  width:200%;height:1px;background:var(--blue);
  transform-origin:left center;
}
.chC-lines::before{top:30%;transform:rotate(-8deg)}
.chC-lines::after{top:60%;transform:rotate(-8deg)}

.chC-inner{
  position:relative;z-index:2;
  max-width:1320px;margin:0 auto;padding:100px 6%;
  display:grid;grid-template-columns:1.1fr 0.9fr;
  gap:80px;align-items:center;
}
.event-mega-badge{
  position:relative;display:flex;justify-content:center;align-items:center;
}
.emb-outer{
  width:380px;height:380px;border-radius:50%;
  background:conic-gradient(
    rgba(0,120,191,0.15) 0deg,
    rgba(0,168,255,0.3) 90deg,
    rgba(0,120,191,0.15) 180deg,
    rgba(0,50,100,0.25) 270deg,
    rgba(0,120,191,0.15) 360deg
  );
  display:flex;align-items:center;justify-content:center;
  animation:badgeSpin 20s linear infinite;
  box-shadow:0 0 80px rgba(0,120,191,0.2);
}
@keyframes badgeSpin{from{transform:rotate(0)}to{transform:rotate(360deg)}}
.emb-inner{
  width:340px;height:340px;border-radius:50%;
  background:linear-gradient(145deg,#0d4a8a,#0a3d7a,#0078BF 200%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:32px;
  box-shadow:inset 0 0 60px rgba(0,20,60,0.5),0 0 60px rgba(0,80,160,0.3);
  animation:badgeSpin 20s linear infinite reverse;
}
.emb-star{font-size:36px;margin-bottom:10px}
.emb-eyebrow{
  font-size:9px;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;
  color:rgba(255,255,255,0.45);margin-bottom:12px;
}
.emb-title{
  font-family:'Bebas Neue',sans-serif;
  font-size:44px;line-height:1;color:white;letter-spacing:0.02em;
  margin-bottom:6px;
}
.emb-sub{font-size:11px;color:rgba(255,255,255,0.4);line-height:1.5}

/* Event detail strips */
.event-details{display:flex;flex-direction:column;gap:0}
.ev-strip{
  display:flex;align-items:center;gap:20px;
  padding:22px 0;
  border-bottom:1px solid rgba(0,80,160,0.1);
  transition:all .3s;cursor:default;
}
.ev-strip:last-child{border-bottom:none}
.ev-strip:hover{padding-left:8px}
.ev-strip-icon{
  width:44px;height:44px;border-radius:12px;flex-shrink:0;
  background:rgba(0,120,191,0.12);
  display:flex;align-items:center;justify-content:center;font-size:20px;
  transition:background .3s;
}
.ev-strip:hover .ev-strip-icon{background:rgba(0,120,191,0.22)}
.ev-strip-label{
  font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;
  color:rgba(26,37,53,0.4);margin-bottom:4px;
}
.ev-strip-value{font-size:15px;font-weight:500;color:#0a1e35;line-height:1.35}

/* ══════════════════════════════════════════
   CHAPTER D — Why Neelgiri | horizontal scroll feel
══════════════════════════════════════════ */
#chD{
  background:linear-gradient(180deg,#f4f7fb 0%,#eaf2fd 50%,#f4f7fb 100%);
  padding:120px 0;overflow:hidden;
}
.chD-header{
  text-align:center;padding:0 6%;margin-bottom:70px;
}
/* Masonry-ish grid */
.why-masonry{
  display:grid;
  grid-template-columns:repeat(12,1fr);
  grid-template-rows:auto;
  gap:16px;
  padding:0 6%;
  max-width:1400px;margin:0 auto;
}
.wm-card{
  position:relative;overflow:hidden;
